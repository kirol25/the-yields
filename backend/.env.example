# Example environment variables for local development.
ENVIRONMENT=local

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/the_yields

# Auth mode: 'local' skips JWT verification and injects a fixed dev user so
# `docker compose up` works without setting up Cognito. Set to 'cognito' for
# any non-local deployment.
AUTH_MODE=local

# Cognito JWT verification (required when AUTH_MODE=cognito)
COGNITO_REGION=eu-central-1
COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxxx

# SES - feedback emails
# Source must be within the verified SES domain (e.g. the-yields.com)
FEEDBACK_FROM_EMAIL=noreply@the-yields.com
FEEDBACK_TO_EMAIL=you@example.com
