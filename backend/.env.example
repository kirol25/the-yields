# Storage backend: "local" (default) for development, "s3" for production
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
S3_BUCKET=your-bucket-name
S3_PREFIX=data

# Cognito JWT verification — set to your Cognito region in production.
# Header-based auth is disabled unless ALLOW_INSECURE_DEV_AUTH=true.
COGNITO_USER_POOL_ID=eu-central-1_xxxxxxxxx
ALLOW_INSECURE_DEV_AUTH=false

# Stripe — leave empty to disable subscription endpoints until Stripe is configured.
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_MONTHLY=price_...
STRIPE_PRICE_ID_YEARLY=price_...
APP_URL=https://the-yields.app
