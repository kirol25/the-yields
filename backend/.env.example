# Storage backend: "local" (default) for development, "s3" for production
STORAGE_BACKEND=local

# Required when STORAGE_BACKEND=s3
S3_BUCKET=your-bucket-name
S3_PREFIX=data

# Cognito JWT verification — set to your Cognito region in production.
# Leave empty in local dev to skip verification and trust X-User-Email header.
COGNITO_REGION=eu-central-1
