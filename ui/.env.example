# Copy this file to .env.local and fill in your values
# .env.local is gitignored — never commit real values

# ── Backend ───────────────────────────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000

# ── AWS Cognito ───────────────────────────────────────────────────────────────
# App client ID from the Cognito User Pool
VITE_COGNITO_CLIENT_ID=client_id

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to true to allow new user registrations
VITE_REGISTRATION_ENABLED=true

# Set to true once Stripe is configured on the backend to enable checkout buttons
VITE_STRIPE_ENABLED=false

# ── AWS Console prerequisite ──────────────────────────────────────────────────
# Enable USER_PASSWORD_AUTH on the App Client:
# Cognito → User Pools → App clients → Edit → Authentication flows
# Check "ALLOW_USER_PASSWORD_AUTH"
